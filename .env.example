# =============================================================================
# Book Exercise RAG — copy to .env and fill in your values
# =============================================================================

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Supabase project (Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Book scope — run in Supabase SQL editor after migration:
#   select b.id as book_id, c.id as class_id, s.id as subject_id
#   from books b
#   join academic_classes c on c.id = b.class_id
#   join subjects s on s.id = b.subject_id
#   where c.grade = 9 and s.code = 'physics';
BOOK_ID=
CLASS_ID=
SUBJECT_ID=

# Path to the PDF (relative to project root)
PDF_PATH=Physics 9.pdf

# Tutor API (widget)
API_PORT=8000

# Groq fallback when Gemini 2.5 Flash is unavailable (https://console.groq.com)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# Tried in order after primary. Top-tier first; 8b last for speed/cost.
GROQ_CHAT_FALLBACK_MODELS=openai/gpt-oss-120b,qwen/qwen3-32b,openai/gpt-oss-20b,meta-llama/llama-4-scout-17b-16e-instruct,llama-3.1-8b-instant

# Voice — cloud inference only (no local model downloads)
VOICE_ENABLED=true

# Speech-to-text via Groq Whisper (uses GROQ_API_KEY above)
GROQ_WHISPER_MODEL=whisper-large-v3
# Optional fallback; leave empty for large-v3 only (best for Urdu)
GROQ_WHISPER_FALLBACK_MODEL=
STT_LANGUAGE=both
# Widget sends ur/en per selection. Server fallback: both | ur | en
STT_OUTPUT=auto
STT_USE_PROMPT=false
STT_MIN_AUDIO_BYTES=6000
STT_REFINE_ENABLED=false

# Dual-payload tutor replies: display_text (Roman) + speech_text (Urdu script for TTS)
DUAL_PAYLOAD_MODE=true

# Text-to-speech — edge (default) | roman_urdu | kokoro | openai
TTS_PROVIDER=edge
EDGE_TTS_VOICE_UR=ur-PK-UzmaNeural
EDGE_TTS_LANG_MODE=roman_mixed
# Roman Urdu → Urdu script for TTS: auto (LLM first, Mavkif fallback) | llm | mavkif
EDGE_TTS_ROMAN_PREP=auto
MAVKIF_DEVICE=cpu
MAVKIF_USE_ONLY_IF_CACHED=true
MAVKIF_PRELOAD=true
EDGE_TTS_BASE_RATE_PCT=-10
EDGE_TTS_PITCH=+3Hz
EDGE_TTS_VOLUME=-3%
# Physics in speech: urdu (default, single Uzma voice) | hybrid | english
# urdu = velocity→رفتار, acceleration→تعجیل (smooth one voice)
# hybrid = Uzma + English voice for physics (optional; use en-IN-NeerjaNeural not American Jenny)
EDGE_TTS_PHYSICS_TERMS=urdu
EDGE_TTS_VOICE_EN=en-IN-NeerjaNeural
EDGE_TTS_HYBRID_PAUSE_MS=70
EDGE_TTS_CHUNK_CHARS=380
EDGE_TTS_PREP_CHUNK_CHARS=480
EDGE_TTS_CHUNK_PAUSE_MS=280
EDGE_TTS_SENTENCE_MODE=true
EDGE_TTS_SENTENCE_CHARS=150
URDU_TTS_MODEL=facebook/mms-tts-urd-script_latin
URDU_TTS_ROMAN_TO_SCRIPT=false
URDU_TTS_DEVICE=cpu
URDU_TTS_SEED=42
URDU_TTS_PRELOAD=false

# Kokoro local/cloud
KOKORO_BACKEND=local
KOKORO_TTS_ENABLED=true
KOKORO_LANG_MODE=roman_mixed
KOKORO_SPEED=0.9
KOKORO_VOICE_UR=hf_beta
KOKORO_VOICE_EN=af_bella
HF_TTS_MODEL=hexgrad/Kokoro-82M

# Optional paid Roman Urdu (set TTS_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
