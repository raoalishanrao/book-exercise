# =============================================================================
# Book Exercise RAG — copy to .env and fill in your values
# =============================================================================

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Supabase project (Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Book scope — run in Supabase SQL editor after migration:
#   select b.id as book_id, c.id as class_id, s.id as subject_id
#   from books b
#   join academic_classes c on c.id = b.class_id
#   join subjects s on s.id = b.subject_id
#   where c.grade = 9 and s.code = 'physics';
BOOK_ID=
CLASS_ID=
SUBJECT_ID=

# Path to the PDF (relative to project root)
PDF_PATH=Physics 9.pdf

# Tutor API (widget)
API_PORT=8000

# Groq fallback when Gemini 2.5 Flash is unavailable (https://console.groq.com)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# Tried in order after primary. Top-tier first; 8b last for speed/cost.
GROQ_CHAT_FALLBACK_MODELS=openai/gpt-oss-120b,qwen/qwen3-32b,openai/gpt-oss-20b,meta-llama/llama-4-scout-17b-16e-instruct,llama-3.1-8b-instant

# Voice — cloud inference only (no local model downloads)
VOICE_ENABLED=true

# Speech-to-text via Groq Whisper (uses GROQ_API_KEY above)
GROQ_WHISPER_MODEL=whisper-large-v3
# Optional fallback; leave empty for large-v3 only (best for Urdu)
GROQ_WHISPER_FALLBACK_MODEL=
STT_LANGUAGE=both
# Widget sends ur/en per selection. Server fallback: both | ur | en
STT_OUTPUT=auto
STT_USE_PROMPT=false
STT_MIN_AUDIO_BYTES=6000
STT_REFINE_ENABLED=false

# Kokoro TTS via Hugging Face Inference — kept for later, off by default
KOKORO_TTS_ENABLED=false
# Create token: https://huggingface.co/settings/tokens
HF_TOKEN=
HF_TTS_PROVIDER=fal-ai
HF_TTS_MODEL=hexgrad/Kokoro-82M
KOKORO_VOICE_EN=af_heart
KOKORO_VOICE_UR=hf_alpha
